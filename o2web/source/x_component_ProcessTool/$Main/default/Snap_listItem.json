{
  "viewSetting": {
    "html": "<table width='100%' border='0' cellpadding='5' cellspacing='0' styles='editTable' style='table-layout:fixed;'></table>"
  },
  "headSetting": {
    "html": "<tr styles='viewHeadNode'></tr>"
  },
  "documentSetting": {
    "html": "<tr styles='documentNode'></tr>",
    "mouseoverStyles": "documentNode_over",
    "mousedownStyles": "documentNode_down",
    "holdMouseDownStyles" : true,
    //    "action": "open"
  },
  "items": [
    {
      "name": "$checkbox",
      "head": {
        "html": "<th styles='normalThNode'></th>",
        "width": "30"
      },
      "content": {
        "html": "<td styles='normalTdNode'></td>"
      }
    },
    {
      "name": "title",
      "head": {
        "html": "<th styles='normalThNode' lable='data_title'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' width='58%' item='title'></td>",
        "items": {
          "title": {
            "value":"function(d){ return d.title===''?'无标题':d.title }",
            "action" : "open"

          }
        }
      }
    },
    {
      "name": "activityName",
      "head": {
        "html": "<th styles='normalThNode' lable='data_activityName'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' item='activityName'></td>",
        "items": { "activityName" : {} }
      }
    },
    {
      "name": "applicationName",
      "head": {
        "html": "<th styles='normalThNode' lable='data_applicationName'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' item='applicationName'></td>",
        "items": { "applicationName" : {} }
      }
    },
    {
      "name": "processName",
      "head": {
        "html": "<th styles='normalThNode' lable='data_processName'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' item='processName'></td>",
        "items": { "processName" : {} }
      }
    },
    {
      "name": "creatorPerson",
      "head": {
        "html": "<th styles='normalThNode' lable='data_creatorPerson'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' item='creatorPerson'></td>",
        "items": {
          "creatorPerson": {"value" : "function(d){ return d.creatorPerson.split('@')[0] }"}
        }
      }
    },
    {
      "name": "creatorUnit",
      "head": {
        "html": "<th styles='normalThNode' lable='data_creatorUnit'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' item='creatorUnit'></td>",
        "items": {
          "creatorUnit": {"value" : "function(d){ return d.creatorUnit.split('@')[0] }"}
        }
      }
    },
    {
      "name": "createTime",
      "head": {
        "html": "<th styles='normalThNode' lable='data_createTime'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' item='createTime'></td>",
        "items": { "createTime" : {} }
      }
    },
    {
      "name": "actionList",
      "head": {
        "html": "<th styles='normalThNode' lable='data_op'></th>",
        "width": "100"
      },
      "content": {
        "html": "<td styles='normalTdNode'><div styles='downloadAction' item='downloadAction'></div><div styles='restoreAction' item='restoreAction'></div><div styles='removeAction' item='removeAction'></div></td>",
        "items": {
          "downloadAction": {
            "title": "download",
            "action": "download",
            "styles" : "downloadAction",
            "mouseoverStyles": "downloadAction_over"
          },
          "restoreAction": {
            "title": "restore",
            "action": "restore",
            "styles" : "restoreAction",
            "mouseoverStyles": "restoreAction_over"
          },
          "removeAction": {
            "title": "remove",
            "action": "remove",
            "styles" : "removeAction",
            "mouseoverStyles": "removeAction_over"
          }
        }
      }
    }
  ]
}
