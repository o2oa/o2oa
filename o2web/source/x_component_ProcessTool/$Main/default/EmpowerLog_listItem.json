{
  "viewSetting": {
    "html": "<table width='100%' border='0' cellpadding='5' cellspacing='0' styles='editTable' style='table-layout:fixed;'></table>"
  },
  "headSetting": {
    "html": "<tr styles='viewHeadNode'></tr>"
  },
  "documentSetting": {
    "html": "<tr styles='documentNode'></tr>",
    "mouseoverStyles": "documentNode_over",
    "mousedownStyles": "documentNode_down",
    "holdMouseDownStyles" : true,
    //    "action": "open"
  },
  "items": [
    {
      "name": "$checkbox",
      "head": {
        "html": "<th styles='normalThNode'></th>",
        "width": "30"
      },
      "content": {
        "html": "<td styles='normalTdNode'></td>"
      }
    },
    {
      "name": "title",
      "head": {
        "html": "<th styles='normalThNode' lable='data_title'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' width='58%' item='title'></td>",
        "items": {
          "title": {
            "value":"function(d){ return d.title===''?'无标题':d.title }",
            "action" : "open"
          }
        }
      }
    },
    {
      "name": "fromIdentity",
      "head": {
        "html": "<th styles='normalThNode' lable='data_fromIdentity'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' width='58%' item='fromIdentity'></td>",
        "items": {
          "fromIdentity": {
            "value":"function(d){ return d.fromIdentity.split('@')[0] }",
            "action" : "open"

          }
        }
      }
    },
    {
      "name": "toIdentity",
      "head": {
        "html": "<th styles='normalThNode' lable='data_toIdentity'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' width='58%' item='toIdentity'></td>",
        "items": {
          "toIdentity": {
            "value":"function(d){ return d.toIdentity.split('@')[0] }",
            "action" : "open"

          }
        }
      }
    },
    {
      "name": "processName",
      "head": {
        "html": "<th styles='normalThNode' lable='data_processName'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' item='processName'></td>",
        "items": {
          "processName": {
          }
        }
      }
    },
    {
      "name": "applicationName",
      "head": {
        "html": "<th styles='normalThNode' lable='data_applicationName'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' item='applicationName'></td>",
        "items": { "applicationName" : {} }
      }
    },
    {
      "name": "activityName",
      "head": {
        "html": "<th styles='normalThNode' lable='data_activityName'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' item='activityName'></td>",
        "items": { "activityName" : {} }
      }
    },
    {
      "name": "empowerTime",
      "head": {
        "html": "<th styles='normalThNode' lable='data_empowerTime'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' item='empowerTime'></td>",
        "items": { "empowerTime" : {} }
      }
    },
    {
      "name": "actionList",
      "head": {
        "html": "<th styles='normalThNode' lable='data_op'></th>",
        "width": "100"
      },
      "content": {
        "html": "<td styles='normalTdNode'><div styles='removeAction' item='removeAction'></div></td>",
        "items": {
          "removeAction": {
            "title": "remove",
            "action": "remove",
            "styles" : "removeAction",
            "mouseoverStyles": "removeAction_over"
          }
        }
      }
    }
  ]
}
