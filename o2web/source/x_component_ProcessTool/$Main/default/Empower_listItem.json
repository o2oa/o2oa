{
  "viewSetting": {
    "html": "<table width='100%' border='0' cellpadding='5' cellspacing='0' styles='editTable' style='table-layout:fixed;'></table>"
  },
  "headSetting": {
    "html": "<tr styles='viewHeadNode'></tr>"
  },
  "documentSetting": {
    "html": "<tr styles='documentNode'></tr>",
    "mouseoverStyles": "documentNode_over",
    "mousedownStyles": "documentNode_down",
    "holdMouseDownStyles" : true,
    //    "action": "open"
  },
  "items": [
    {
      "name": "$checkbox",
      "head": {
        "html": "<th styles='normalThNode'></th>",
        "width": "30"
      },
      "content": {
        "html": "<td styles='normalTdNode'></td>"
      }
    },
    {
      "name": "fromIdentity",
      "head": {
        "html": "<th styles='normalThNode' lable='data_fromIdentity'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' width='58%' item='fromIdentity'></td>",
        "items": {
          "fromIdentity": {
            "value":"function(d){ return d.fromIdentity.split('@')[0] }",
            "action" : "open"

          }
        }
      }
    },
    {
      "name": "toIdentity",
      "head": {
        "html": "<th styles='normalThNode' lable='data_toIdentity'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' width='58%' item='toIdentity'></td>",
        "items": {
          "toIdentity": {
            "value":"function(d){ return d.toIdentity.split('@')[0] }",
            "action" : "open"

          }
        }
      }
    },
    {
      "name": "type",
      "head": {
        "html": "<th styles='normalThNode' lable='data_type'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' width='58%' item='type'></td>",
        "items": {
          "type": {
            "value":"function(d){ return d.type==='all'?'全部':d.type==='application'?'应用':'流程'}",
            "action" : "open"

          }
        }
      }
    },
    {
      "name": "processOrApplicatinonName",
      "head": {
        "html": "<th styles='normalThNode' lable='data_processOrApplicatinonName'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' item='processOrApplicatinonName'></td>",
        "items": {
          "processOrApplicatinonName": {
            "value":"function(d){ return d.type == 'all'?'-':d.type=='application'?d.applicationName:d.processName}",
            "action" : "open"

          }
        }
      }
    },
    {
      "name": "startTime",
      "head": {
        "html": "<th styles='normalThNode' lable='data_startTime'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' item='startTime'></td>",
        "items": { "startTime" : {} }
      }
    },
    {
      "name": "completedTime",
      "head": {
        "html": "<th styles='normalThNode' lable='data_completedTime'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' item='completedTime'></td>",
        "items": { "completedTime" : {} }
      }
    },
    {
      "name": "enable",
      "head": {
        "html": "<th styles='normalThNode' lable='data_enable'></th>",
        "width": ""
      },
      "content": {
        "html": "<td styles='normalTdNode' item='enable'></td>",
        "items": { "enable" : {} }
      }
    },
    {
      "name": "actionList",
      "head": {
        "html": "<th styles='normalThNode' lable='data_op'></th>",
        "width": "100"
      },
      "content": {
        "html": "<td styles='normalTdNode'><div styles='opinionAction' item='editAction'></div><div styles='removeAction' item='removeAction'></div></td>",
        "items": {
          "editAction": {
            "title": "editAction",
            "action": "edit",
            "styles" : "opinionAction",
            "mouseoverStyles": "opinionAction_over"
          },
          "removeAction": {
            "title": "remove",
            "action": "remove",
            "styles" : "removeAction",
            "mouseoverStyles": "removeAction_over"
          }
        }
      }
    }
  ]
}
